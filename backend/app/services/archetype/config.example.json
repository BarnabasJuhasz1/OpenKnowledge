{
  "_comment": "Archetype classifier config. Copy to config.json and edit paths. Override the location with the ARCHETYPE_CONFIG_PATH env var.",
  "enabled": true,
  "preload_on_startup": true,

  "_python_executable": "Interpreter of the dedicated conda env that has torch+transformers+safetensors.",
  "python_executable": "/home/<you>/miniforge3/envs/okarchetype/bin/python",

  "_script_path": "Absolute path to classify_retrieved_papers.py.",
  "script_path": "/abs/path/to/archetype_classifier/classifier/classify_retrieved_papers.py",

  "_checkpoint_dir": "Fine-tuned checkpoint dir containing model.safetensors + tokenizer files.",
  "checkpoint_dir": "/abs/path/to/archetype_classifier/models/fast_archetype_model/checkpoint-6402",

  "_label_mapping_path": "label_mapping.json with primary/secondary id->label dicts.",
  "label_mapping_path": "/abs/path/to/archetype_classifier/models/fast_archetype_model/label_mapping.json",

  "_encoder_config": "Static BERT/SciBERT architecture used to rebuild the encoder offline (weights come from the checkpoint).",
  "encoder_config": {
    "model_type": "bert",
    "vocab_size": 31090,
    "hidden_size": 768,
    "num_hidden_layers": 12,
    "num_attention_heads": 12,
    "intermediate_size": 3072,
    "hidden_act": "gelu",
    "hidden_dropout_prob": 0.1,
    "attention_probs_dropout_prob": 0.1,
    "max_position_embeddings": 512,
    "type_vocab_size": 2,
    "initializer_range": 0.02,
    "layer_norm_eps": 1e-12,
    "pad_token_id": 0
  },

  "batch_size": 64,
  "max_length": 512,
  "_device": "auto | cuda | cpu",
  "device": "auto",
  "request_timeout_seconds": 120,
  "startup_timeout_seconds": 180
}
